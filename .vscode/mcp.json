{
	"servers": {
		"filesystem": {
			"type": "stdio",
			"command": "${workspaceFolder}/.github/hooks/scripts/mcp-npx.sh",
			"args": [
				"-y",
				"@modelcontextprotocol/server-filesystem",
				"${workspaceFolder}"
			]
		},
		"git": {
			"type": "stdio",
			"command": "${workspaceFolder}/.github/hooks/scripts/mcp-uvx.sh",
			"args": [
				"mcp-server-git",
				"--repository",
				"${workspaceFolder}"
			]
		},
		"github": {
			"type": "http",
			"url": "https://api.githubcopilot.com/mcp/"
		},
		"fetch": {
			"type": "stdio",
			"command": "${workspaceFolder}/.github/hooks/scripts/mcp-uvx.sh",
			"args": [
				"mcp-server-fetch"
			]
		},
		"context7": {
			"type": "http",
			"url": "https://mcp.context7.com/mcp"
		},
		"heartbeat": {
			"type": "stdio",
			"command": "${workspaceFolder}/.github/hooks/scripts/mcp-uvx.sh",
			"args": [
				"--from", "mcp[cli]",
				"mcp", "run",
				"${workspaceFolder}/.github/hooks/scripts/mcp-heartbeat-server.py"
			]
		}
	}
}