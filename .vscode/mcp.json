{
	"servers": {
		"filesystem": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-filesystem",
				"${workspaceFolder}"
			]
		},
		"git": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"mcp-server-git",
				"--repository",
				"${workspaceFolder}"
			]
		},
		"github": {
			"type": "http",
			"url": "https://api.githubcopilot.com/mcp/"
		},
		"fetch": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"mcp-server-fetch"
			]
		},
		"context7": {
			"type": "http",
			"url": "https://mcp.context7.com/mcp"
		}
	}
}