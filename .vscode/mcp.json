{
	"sandbox": {
		"filesystem": {
			"allowWrite": [
				"${userHome}/.npm"
			]
		}
	},
	"servers": {
		"filesystem": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-filesystem@2026.1.14",
				"${workspaceFolder}"
			],
			"sandboxEnabled": true,
			"sandbox": {
				"network": {
					"allowedDomains": [
						"registry.npmjs.org",
						"npmjs.org"
					]
				},
				"filesystem": {
					"allowWrite": [
						"${workspaceFolder}",
						"${userHome}/.npm"
					],
					"denyRead": [
						"${userHome}/.ssh",
						"${userHome}/.gnupg",
						"${userHome}/.aws",
						"${userHome}/.netrc",
						"${userHome}/.docker",
						"${userHome}/.kube",
						"${userHome}/.config",
						"${userHome}/.bash_history",
						"${userHome}/.zsh_history",
						"${userHome}/.local/share/keyrings"
					]
				}
			}
		},
		"git": {
			"type": "stdio",
			"command": "uvx",
			"env": {
				"GIT_MCP_REPOSITORY": "${workspaceFolder}",
				"CLAUDE_TMPDIR": "${userHome}/.cache/uv",
				"TMPDIR": "${userHome}/.cache/uv"
			},
			"args": [
				"--from", "mcp[cli]",
				"--with", "gitpython>=3.1.50,<3.2",
				"mcp", "run",
				"${workspaceFolder}/hooks/scripts/mcp-git-server.py"
			]
		},
		"github": {
			"type": "http",
			"url": "https://api.githubcopilot.com/mcp/readonly",
			"headers": {
				"X-MCP-Toolsets": "issues,pull_requests,actions,dependabot"
			},
			"disabled": true
		},
		"fetch": {
			"type": "stdio",
			"command": "uvx",
			"env": {
				"CLAUDE_TMPDIR": "${userHome}/.cache/uv",
				"TMPDIR": "${userHome}/.cache/uv"
			},
			"args": [
				"mcp-server-fetch==2025.4.7"
			]
		},
		"heartbeat": {
			"type": "stdio",
			"command": "uvx",
			"env": {
				"HEARTBEAT_WORKSPACE": "${workspaceFolder}",
				"CLAUDE_TMPDIR": "${userHome}/.cache/uv/.copilot-tmp",
				"TMPDIR": "${userHome}/.cache/uv/.copilot-tmp"
			},
			"args": [
				"--from",
				"mcp[cli]",
				"mcp",
				"run",
				"${workspaceFolder}/hooks/scripts/mcp-heartbeat-server.py"
			]
		},
		"context7": {
			"type": "http",
			"url": "https://mcp.context7.com/mcp"
		},
		"sequential-thinking": {
			"type": "stdio",
			"command": "uvx",
			"env": {
				"CLAUDE_TMPDIR": "${userHome}/.cache/uv",
				"TMPDIR": "${userHome}/.cache/uv"
			},
			"args": [
				"--from",
				"mcp[cli]",
				"mcp",
				"run",
				"${workspaceFolder}/hooks/scripts/mcp-sequential-thinking-server.py"
			]
		},
		"duckduckgo": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"--from", "mcp[cli]",
				"--with", "httpx>=0.27,<1",
				"--with", "beautifulsoup4>=4.12",
				"mcp", "run",
				"${workspaceFolder}/hooks/scripts/mcp-duckduckgo-server.py"
			]
		}
	}
}