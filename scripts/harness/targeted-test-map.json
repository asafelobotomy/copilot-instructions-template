{
  "schemaVersion": "2.0",
  "description": "Deterministic path-to-targeted-test mapping with risk-based escalation for intermediate-phase verification in copilot-instructions-template.",
  "defaults": {
    "unmappedPhaseStrategy": "broaden-aggressively",
    "runFullSuiteAtCompletion": false,
    "runFullSuiteAtCompletionOnMultipleDomains": 4,
    "runFullSuiteAtCompletionOnMultiplePhases": 3,
    "runFullSuiteAtCompletionOnMultipleSuites": 4,
    "intermediatePhaseBudgetSeconds": 10,
    "earlyFullSuiteOnCriticalSurface": true,
    "earlyFullSuiteOnMultipleBroadenDomains": 3,
    "confidenceFloor": 0.5,
    "trackedFilePatterns": [
      "Makefile",
      "*.lock",
      "requirements*.txt",
      ".github/workflows/*.yml"
    ]
  },
  "mirrorDomains": {
    "hooks-mirror": [".github/hooks/", "template/hooks/"],
    "skills-mirror": [".github/skills/", "template/skills/"],
    "workspace-mirror": [".copilot/workspace/", "template/workspace/"]
  },
  "riskClasses": ["critical-surface", "security-sensitive", "cross-cutting"],
  "ruleFiles": [
    "scripts/harness/targeted-test-map.d/00-selector-core.json",
    "scripts/harness/targeted-test-map.d/10-repo-scripts.json",
    "scripts/harness/targeted-test-map.d/20-hooks.json",
    "scripts/harness/targeted-test-map.d/30-docs-and-surfaces.json"
  ]
}