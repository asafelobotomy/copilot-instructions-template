{
  "description": "Documentation, customization, starter-kit, and release metadata surfaces.",
  "rules": [
    {
      "id": "agent-files",
      "matchType": "glob",
      "pattern": ".github/agents/*.agent.md",
      "phaseStrategy": "targeted",
      "tests": [
        "tests/contracts/test-customization-contracts.sh",
        "tests/scripts/test-copilot-audit.sh",
        "tests/scripts/test-sync-models.sh",
        "tests/scripts/test-validate-agent-frontmatter.sh"
      ],
      "reason": "Agent definitions participate in customization contracts, audit checks, model sync, and frontmatter validation."
    },
    {
      "id": "models-registry",
      "matchType": "exact",
      "pattern": "MODELS.md",
      "phaseStrategy": "targeted",
      "tests": [
        "tests/scripts/test-sync-models.sh"
      ],
      "reason": "MODELS.md is validated by the sync-models contract suite."
    },
    {
      "id": "llms-registry",
      "matchType": "exact",
      "pattern": "llms.txt",
      "phaseStrategy": "targeted",
      "tests": [
        "tests/scripts/test-sync-models.sh"
      ],
      "reason": "llms.txt is validated by the sync-models contract suite."
    },
    {
      "id": "customization-instructions",
      "matchType": "prefix",
      "pattern": ".github/instructions/",
      "phaseStrategy": "targeted",
      "tests": [
        "tests/contracts/test-customization-contracts.sh",
        "tests/contracts/test-template-parity.sh"
      ],
      "reason": "Developer instruction stubs are covered by customization contracts and parity checks."
    },
    {
      "id": "customization-prompts",
      "matchType": "prefix",
      "pattern": ".github/prompts/",
      "phaseStrategy": "targeted",
      "tests": [
        "tests/contracts/test-customization-contracts.sh",
        "tests/contracts/test-template-parity.sh"
      ],
      "reason": "Developer prompts are covered by customization contracts and parity checks."
    },
    {
      "id": "customization-skills",
      "matchType": "prefix",
      "pattern": ".github/skills/",
      "phaseStrategy": "targeted",
      "tests": [
        "tests/contracts/test-customization-contracts.sh",
        "tests/contracts/test-template-parity.sh"
      ],
      "reason": "Developer skills are covered by customization contracts and parity checks."
    },
    {
      "id": "template-instructions",
      "matchType": "prefix",
      "pattern": "template/instructions/",
      "phaseStrategy": "targeted",
      "tests": [
        "tests/contracts/test-customization-contracts.sh",
        "tests/contracts/test-template-parity.sh"
      ],
      "reason": "Template instruction stubs are covered by customization contracts and parity checks."
    },
    {
      "id": "template-prompts",
      "matchType": "prefix",
      "pattern": "template/prompts/",
      "phaseStrategy": "targeted",
      "tests": [
        "tests/contracts/test-customization-contracts.sh",
        "tests/contracts/test-template-parity.sh"
      ],
      "reason": "Template prompt stubs are covered by customization contracts and parity checks."
    },
    {
      "id": "template-skills",
      "matchType": "prefix",
      "pattern": "template/skills/",
      "phaseStrategy": "targeted",
      "tests": [
        "tests/contracts/test-customization-contracts.sh",
        "tests/contracts/test-template-parity.sh"
      ],
      "reason": "Template skills are covered by customization contracts and parity checks."
    },
    {
      "id": "developer-copilot-instructions",
      "matchType": "exact",
      "pattern": ".github/copilot-instructions.md",
      "phaseStrategy": "targeted",
      "tests": [
        "tests/contracts/test-customization-contracts.sh",
        "tests/scripts/test-copilot-audit.sh"
      ],
      "reason": "Developer instructions are covered by customization contracts and copilot audit checks."
    },
    {
      "id": "template-copilot-instructions",
      "matchType": "exact",
      "pattern": "template/copilot-instructions.md",
      "phaseStrategy": "targeted",
      "tests": [
        "tests/contracts/test-customization-contracts.sh",
        "tests/contracts/test-setup-update-contracts.sh",
        "tests/scripts/test-copilot-audit.sh"
      ],
      "reason": "Template instructions participate in customization contracts, setup/update contracts, and copilot audit checks."
    },
    {
      "id": "template-claude-surface",
      "matchType": "exact",
      "pattern": "template/CLAUDE.md",
      "phaseStrategy": "targeted",
      "tests": [
        "tests/contracts/test-customization-contracts.sh"
      ],
      "reason": "template/CLAUDE.md is covered by the customization contract suite."
    },
    {
      "id": "template-vscode-settings-surface",
      "matchType": "exact",
      "pattern": "template/vscode/settings.json",
      "phaseStrategy": "targeted",
      "tests": [
        "tests/contracts/test-setup-update-contracts.sh"
      ],
      "reason": "Template VS Code settings participate in setup/update contract coverage."
    },
    {
      "id": "template-vscode-extensions-surface",
      "matchType": "exact",
      "pattern": "template/vscode/extensions.json",
      "phaseStrategy": "targeted",
      "tests": [
        "tests/contracts/test-setup-update-contracts.sh"
      ],
      "reason": "Template VS Code extension recommendations participate in setup/update contract coverage."
    },
    {
      "id": "template-vscode-mcp-surface",
      "matchType": "exact",
      "pattern": "template/vscode/mcp.json",
      "phaseStrategy": "targeted",
      "tests": [
        "tests/contracts/test-setup-update-contracts.sh"
      ],
      "reason": "Template MCP config parity is guarded by the setup/update contract suite."
    },
    {
      "id": "agents-doc",
      "matchType": "exact",
      "pattern": "AGENTS.md",
      "phaseStrategy": "targeted",
      "tests": [
        "tests/contracts/test-customization-contracts.sh"
      ],
      "reason": "AGENTS.md drives customization policy and should run the customization contract suite."
    },
    {
      "id": "claude-compat-doc",
      "matchType": "exact",
      "pattern": "CLAUDE.md",
      "phaseStrategy": "targeted",
      "tests": [
        "tests/contracts/test-customization-contracts.sh"
      ],
      "reason": "CLAUDE.md is covered by the customization policy contract suite."
    },
    {
      "id": "setup-update-docs",
      "matchType": "exact",
      "pattern": "SETUP.md",
      "phaseStrategy": "targeted",
      "tests": [
        "tests/contracts/test-setup-update-contracts.sh"
      ],
      "reason": "SETUP.md is validated by the setup/update contract suite."
    },
    {
      "id": "setup-manifests-docs",
      "matchType": "exact",
      "pattern": "template/setup/manifests.md",
      "phaseStrategy": "targeted",
      "tests": [
        "tests/contracts/test-setup-update-contracts.sh"
      ],
      "reason": "Setup companion manifests are validated by the setup/update contract suite."
    },
    {
      "id": "update-protocol-docs",
      "matchType": "exact",
      "pattern": "UPDATE.md",
      "phaseStrategy": "targeted",
      "tests": [
        "tests/contracts/test-setup-update-contracts.sh"
      ],
      "reason": "UPDATE.md is validated by the setup/update contract suite."
    },
    {
      "id": "mcp-config",
      "matchType": "exact",
      "pattern": ".vscode/mcp.json",
      "phaseStrategy": "targeted",
      "tests": [
        "tests/scripts/test-copilot-audit.sh",
        "tests/scripts/test-mcp-launchers.sh"
      ],
      "reason": "The MCP config is covered by the audit suite and the launcher contract suite."
    },
    {
      "id": "settings-config",
      "matchType": "glob",
      "pattern": "*.vscode/settings.json",
      "phaseStrategy": "targeted",
      "tests": [
        "tests/contracts/test-customization-contracts.sh",
        "tests/scripts/test-copilot-audit.sh"
      ],
      "reason": "VS Code settings are covered by customization contracts and the audit suite."
    },
    {
      "id": "starter-kits",
      "matchType": "prefix",
      "pattern": "starter-kits/",
      "phaseStrategy": "targeted",
      "tests": [
        "tests/contracts/test-starter-kits.sh"
      ],
      "reason": "Starter-kit assets are validated by the starter-kit contract suite."
    },
    {
      "id": "release-metadata",
      "matchType": "exact",
      "pattern": "VERSION.md",
      "phaseStrategy": "targeted",
      "tests": [
        "tests/contracts/test-release-contracts.sh"
      ],
      "reason": "Release metadata files are validated by the release contract suite."
    },
    {
      "id": "release-changelog",
      "matchType": "exact",
      "pattern": "CHANGELOG.md",
      "phaseStrategy": "targeted",
      "tests": [
        "tests/contracts/test-release-contracts.sh"
      ],
      "reason": "Release documentation is validated by the release contract suite."
    },
    {
      "id": "release-migration",
      "matchType": "exact",
      "pattern": "MIGRATION.md",
      "phaseStrategy": "targeted",
      "tests": [
        "tests/contracts/test-release-contracts.sh"
      ],
      "reason": "Migration documentation is validated by the release contract suite."
    },
    {
      "id": "release-config",
      "matchType": "exact",
      "pattern": "release-please-config.json",
      "phaseStrategy": "targeted",
      "tests": [
        "tests/contracts/test-release-contracts.sh"
      ],
      "reason": "release-please config is validated by the release contract suite."
    },
    {
      "id": "release-manifest",
      "matchType": "exact",
      "pattern": ".release-please-manifest.json",
      "phaseStrategy": "targeted",
      "tests": [
        "tests/contracts/test-release-contracts.sh"
      ],
      "reason": "release-please manifest is validated by the release contract suite."
    },
    {
      "id": "release-workflows",
      "matchType": "glob",
      "pattern": ".github/workflows/*.yml",
      "phaseStrategy": "targeted",
      "tests": [
        "tests/contracts/test-release-contracts.sh"
      ],
      "reason": "Release workflow contracts validate the CI-integrated release flow."
    }
  ]
}