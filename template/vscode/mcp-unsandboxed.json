{
  "servers": {
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "${workspaceFolder}"]
    },
    "git": {
      "type": "stdio",
      "command": "uvx",
      "args": ["mcp-server-git", "--repository", "${workspaceFolder}"]
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "disabled": true
    },
    "fetch": {
      "type": "stdio",
      "command": "uvx",
      "env": {
        "CLAUDE_TMPDIR": "${userHome}/.cache/uv",
        "TMPDIR": "${userHome}/.cache/uv"
      },
      "args": ["--with", "httpx[socks]>=0.28", "mcp-server-fetch"],
      "disabled": true
    },
    "docs": {
      "type": "stdio",
      "command": "uvx",
      "env": {
        "CLAUDE_TMPDIR": "${userHome}/.cache/uv",
        "TMPDIR": "${userHome}/.cache/uv"
      },
      "args": [
        "--from", "mcp[cli]",
        "--with", "httpx>=0.27,<1",
        "--with", "beautifulsoup4>=4.12",
        "mcp", "run",
        "${workspaceFolder}/.github/hooks/scripts/mcp-docs-server.py"
      ],
      "disabled": true
    },
    "duckduckgo": {
      "type": "stdio",
      "command": "uvx",
      "args": ["duckduckgo-mcp-server"],
      "disabled": true
    },
    "heartbeat": {
      "type": "stdio",
      "command": "uvx",
      "env": {
        "HEARTBEAT_WORKSPACE": "${workspaceFolder}",
        "CLAUDE_TMPDIR": "${userHome}/.cache/uv/.copilot-tmp",
        "TMPDIR": "${userHome}/.cache/uv/.copilot-tmp"
      },
      "args": [
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/.github/hooks/scripts/mcp-heartbeat-server.py"
      ]
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    }
  }
}
