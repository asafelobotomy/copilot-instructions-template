{
  "comment": "Secret detection pattern catalog. Each entry has 'name', 'severity', and platform-specific regex: 'bash' (POSIX ERE for grep -iE) and 'powershell' (.NET regex for -imatch). Edit this file to add, remove, or tune patterns; scan-secrets.sh and scan-secrets.ps1 load it at runtime.",
  "patterns": [
    {"name": "AWS_ACCESS_KEY",          "severity": "critical", "bash": "AKIA[0-9A-Z]{16}",                                                                                                                            "powershell": "AKIA[0-9A-Z]{16}"},
    {"name": "AWS_SECRET_KEY",          "severity": "critical", "bash": "aws_secret_access_key[[:space:]]*[:=][[:space:]]*['\"]?[A-Za-z0-9/+=]{40}",                                                                   "powershell": "aws_secret_access_key\\s*[:=]\\s*['\"']?[A-Za-z0-9/+=]{40}"},
    {"name": "GCP_SERVICE_ACCOUNT",     "severity": "critical", "bash": "\"type\"[[:space:]]*:[[:space:]]*\"service_account\"",                                                                                         "powershell": "\"type\"\\s*:\\s*\"service_account\""},
    {"name": "GCP_API_KEY",             "severity": "high",     "bash": "AIza[0-9A-Za-z_-]{35}",                                                                                                                       "powershell": "AIza[0-9A-Za-z_-]{35}"},
    {"name": "AZURE_CLIENT_SECRET",     "severity": "critical", "bash": "azure[_-]?client[_-]?secret[[:space:]]*[:=][[:space:]]*['\"]?[A-Za-z0-9_~.-]{34,}",                                                           "powershell": "azure[_\\-]?client[_\\-]?secret\\s*[:=]\\s*['\"']?[A-Za-z0-9_~.\\-]{34,}"},
    {"name": "GITHUB_PAT",              "severity": "critical", "bash": "ghp_[0-9A-Za-z]{36}",                                                                                                                         "powershell": "ghp_[0-9A-Za-z]{36}"},
    {"name": "GITHUB_OAUTH",            "severity": "critical", "bash": "gho_[0-9A-Za-z]{36}",                                                                                                                         "powershell": "gho_[0-9A-Za-z]{36}"},
    {"name": "GITHUB_APP_TOKEN",        "severity": "critical", "bash": "ghs_[0-9A-Za-z]{36}",                                                                                                                         "powershell": "ghs_[0-9A-Za-z]{36}"},
    {"name": "GITHUB_REFRESH_TOKEN",    "severity": "critical", "bash": "ghr_[0-9A-Za-z]{36}",                                                                                                                         "powershell": "ghr_[0-9A-Za-z]{36}"},
    {"name": "GITHUB_FINE_GRAINED_PAT", "severity": "critical", "bash": "github_pat_[0-9A-Za-z_]{82}",                                                                                                                 "powershell": "github_pat_[0-9A-Za-z_]{82}"},
    {"name": "PRIVATE_KEY",             "severity": "critical", "bash": "-----BEGIN (RSA |EC |OPENSSH |DSA |PGP )?PRIVATE KEY-----",                                                                                    "powershell": "-----BEGIN (RSA |EC |OPENSSH |DSA |PGP )?PRIVATE KEY-----"},
    {"name": "PGP_PRIVATE_BLOCK",       "severity": "critical", "bash": "-----BEGIN PGP PRIVATE KEY BLOCK-----",                                                                                                        "powershell": "-----BEGIN PGP PRIVATE KEY BLOCK-----"},
    {"name": "GENERIC_SECRET",          "severity": "high",     "bash": "(secret|token|password|passwd|pwd|api[_-]?key|apikey|access[_-]?key|auth[_-]?token|client[_-]?secret)[[:space:]]*[:=][[:space:]]*['\"]?[A-Za-z0-9_/+=~.-]{8,}", "powershell": "(secret|token|password|passwd|pwd|api[_\\-]?key|apikey|access[_\\-]?key|auth[_\\-]?token|client[_\\-]?secret)\\s*[:=]\\s*['\"']?[A-Za-z0-9_/+=~.\\-]{8,}"},
    {"name": "CONNECTION_STRING",       "severity": "high",     "bash": "(mongodb(\\+srv)?|postgres(ql)?|mysql|redis|amqp|mssql)://[^[:space:]'\"]{10,}",                                                              "powershell": "(mongodb(\\+srv)?|postgres(ql)?|mysql|redis|amqp|mssql)://[^\\s'\"]{10,}"},
    {"name": "BEARER_TOKEN",            "severity": "medium",   "bash": "[Bb]earer[[:space:]]+[A-Za-z0-9_-]{20,}\\.[A-Za-z0-9_-]{20,}",                                                                               "powershell": "[Bb]earer\\s+[A-Za-z0-9_\\-]{20,}\\.[A-Za-z0-9_\\-]{20,}"},
    {"name": "SLACK_TOKEN",             "severity": "high",     "bash": "xox[baprs]-[0-9]{10,}-[0-9A-Za-z-]+",                                                                                                         "powershell": "xox[baprs]-[0-9]{10,}-[0-9A-Za-z\\-]+"},
    {"name": "SLACK_WEBHOOK",           "severity": "high",     "bash": "https://hooks\\.slack\\.com/services/T[0-9A-Z]{8,}/B[0-9A-Z]{8,}/[0-9A-Za-z]{24}",                                                           "powershell": "https://hooks\\.slack\\.com/services/T[0-9A-Z]{8,}/B[0-9A-Z]{8,}/[0-9A-Za-z]{24}"},
    {"name": "DISCORD_TOKEN",           "severity": "high",     "bash": "[MN][A-Za-z0-9]{23,}\\.[A-Za-z0-9_-]{6}\\.[A-Za-z0-9_-]{27,}",                                                                               "powershell": "[MN][A-Za-z0-9]{23,}\\.[A-Za-z0-9_\\-]{6}\\.[A-Za-z0-9_\\-]{27,}"},
    {"name": "TWILIO_API_KEY",          "severity": "high",     "bash": "SK[0-9a-fA-F]{32}",                                                                                                                           "powershell": "SK[0-9a-fA-F]{32}"},
    {"name": "SENDGRID_API_KEY",        "severity": "high",     "bash": "SG\\.[0-9A-Za-z_-]{22}\\.[0-9A-Za-z_-]{43}",                                                                                                  "powershell": "SG\\.[0-9A-Za-z_\\-]{22}\\.[0-9A-Za-z_\\-]{43}"},
    {"name": "STRIPE_SECRET_KEY",       "severity": "critical", "bash": "sk_live_[0-9A-Za-z]{24,}",                                                                                                                    "powershell": "sk_live_[0-9A-Za-z]{24,}"},
    {"name": "STRIPE_RESTRICTED_KEY",   "severity": "high",     "bash": "rk_live_[0-9A-Za-z]{24,}",                                                                                                                    "powershell": "rk_live_[0-9A-Za-z]{24,}"},
    {"name": "NPM_TOKEN",               "severity": "high",     "bash": "npm_[0-9A-Za-z]{36}",                                                                                                                         "powershell": "npm_[0-9A-Za-z]{36}"},
    {"name": "JWT_TOKEN",               "severity": "medium",   "bash": "eyJ[A-Za-z0-9_-]{10,}\\.eyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}",                                                                         "powershell": "eyJ[A-Za-z0-9_\\-]{10,}\\.eyJ[A-Za-z0-9_\\-]{10,}\\.[A-Za-z0-9_\\-]{10,}"},
    {"name": "INTERNAL_IP_PORT",        "severity": "medium",   "bash": "(^|[^.0-9])(10\\.[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}|172\\.(1[6-9]|2[0-9]|3[01])\\.[0-9]{1,3}\\.[0-9]{1,3}|192\\.168\\.[0-9]{1,3}\\.[0-9]{1,3}):[0-9]{2,5}([^0-9]|$)", "powershell": "10\\.[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}:[0-9]{2,5}|192\\.168\\.[0-9]{1,3}\\.[0-9]{1,3}:[0-9]{2,5}"}
  ]
}